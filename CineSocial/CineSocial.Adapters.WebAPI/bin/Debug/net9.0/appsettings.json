{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}",
    "AlternativeConnection": "${DB_CONNECTION_STRING}",
    "RedisConnection": "${REDIS_CONNECTION_STRING}"
  },

  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "AccessTokenLifetimeMinutes": "${JWT_ACCESS_TOKEN_LIFETIME_MINUTES}",
    "RefreshTokenLifetimeDays": "${JWT_REFRESH_TOKEN_LIFETIME_DAYS}",
    "Issuer": "CineSocial",
    "Audience": "CineSocial-Users"
  },

  "EmailSettings": {
    "Host": "${EMAIL_HOST}",
    "Port": "${EMAIL_PORT}",
    "Username": "${EMAIL_USERNAME}",
    "Password": "${EMAIL_PASSWORD}",
    "UseTls": "${EMAIL_USE_TLS}",
    "FromEmail": "${EMAIL_FROM}",
    "FromName": "CineSocial"
  },

  "GoogleOAuth": {
    "ClientId": "${GOOGLE_CLIENT_ID}",
    "ClientSecret": "${GOOGLE_CLIENT_SECRET}"
  },

  "CloudinarySettings": {
    "CloudName": "${CLOUDINARY_CLOUD_NAME}",
    "ApiKey": "${CLOUDINARY_API_KEY}",
    "ApiSecret": "${CLOUDINARY_API_SECRET}"
  },

  "SecuritySettings": {
    "SecretKey": "${SECRET_KEY}"
  },

  "CacheSettings": {
    "ExpirationMinutes": "${CACHE_EXPIRATION_MINUTES}",
    "SlidingExpirationMinutes": "${CACHE_SLIDING_EXPIRATION_MINUTES}"
  },

  "CorsSettings": {
    "AllowedOrigins": "${CORS_ALLOWED_ORIGINS}"
  },

  "ApiSettings": {
    "Version": "${API_VERSION}",
    "Title": "${API_TITLE}",
    "Description": "${API_DESCRIPTION}"
  },

  "FileUploadSettings": {
    "MaxFileSizeMB": "${MAX_FILE_SIZE_MB}",
    "AllowedExtensions": "${ALLOWED_FILE_EXTENSIONS}"
  },

  "ExternalAPIs": {
    "TMDB": {
      "ApiKey": "${TMDB_API_KEY}",
      "BaseUrl": "${TMDB_BASE_URL}"
    },
    "AIService": {
      "Url": "${AI_SERVICE_URL}",
      "ApiKey": "${AI_SERVICE_API_KEY}"
    }
  },

  "HealthCheckSettings": {
    "TimeoutSeconds": "${HEALTH_CHECK_TIMEOUT_SECONDS}"
  }
}